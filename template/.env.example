# ══════════════════════════════════════════════════════════════
# {{PROJECT_NAME}} — Environment Variables TEMPLATE
# ══════════════════════════════════════════════════════════════
# Copy to .env and fill in real values.
# Or run setup.sh to generate automatically.
# ══════════════════════════════════════════════════════════════

# ─── MySQL (Docker Compose) ──────────────────────────────────
MYSQL_ROOT_PASSWORD=CHANGE_ME_root_password
MYSQL_DATABASE={{MYSQL_DATABASE}}
MYSQL_USER={{MYSQL_USER}}
MYSQL_PASSWORD=CHANGE_ME_user_password

# ─── WordPress (Docker Compose) ──────────────────────────────
WORDPRESS_DB_HOST=mysql
WORDPRESS_DB_NAME={{MYSQL_DATABASE}}
WORDPRESS_DB_USER={{MYSQL_USER}}
WORDPRESS_DB_PASSWORD=CHANGE_ME_user_password
WORDPRESS_TABLE_PREFIX={{TABLE_PREFIX}}

# ─── MCP Tools (VS Code Copilot) ────────────────────────────
MYSQL_MCP_HOST=127.0.0.1
MYSQL_MCP_PORT={{MYSQL_PORT}}

# ─── Redis ───────────────────────────────────────────────────
REDIS_PASSWORD=CHANGE_ME_redis_password

# ─── WordPress Debug (0=off in prod, 1=on in dev) ───────────
WORDPRESS_DEBUG=0

# ─── WordPress Salts (generate: https://api.wordpress.org/secret-key/1.1/salt/) ─
WORDPRESS_AUTH_KEY=CHANGE_ME_64_char_random
WORDPRESS_SECURE_AUTH_KEY=CHANGE_ME_64_char_random
WORDPRESS_LOGGED_IN_KEY=CHANGE_ME_64_char_random
WORDPRESS_NONCE_KEY=CHANGE_ME_64_char_random
WORDPRESS_AUTH_SALT=CHANGE_ME_64_char_random
WORDPRESS_SECURE_AUTH_SALT=CHANGE_ME_64_char_random
WORDPRESS_LOGGED_IN_SALT=CHANGE_ME_64_char_random
WORDPRESS_NONCE_SALT=CHANGE_ME_64_char_random

# ─── Google Cloud / External APIs ────────────────────────────
# GCP API Key (Maps Embed — browser restricted)
GCP_API_KEY=CHANGE_ME_google_api_key
# GCP Browser API Key (alternative browser-restricted key)
GCP_WEB_API_KEY=CHANGE_ME_gcp_browser_api_key
# GCP Server API Key (reCAPTCHA, server-only APIs — IP restricted)
GCP_SERVER_API_KEY=CHANGE_ME_gcp_server_api_key

# GA4 Analytics
GA4_MEASUREMENT_ID=G-XXXXXXXXXX
GA4_PROPERTY_ID=properties/XXXXXXXXX

# Google OAuth2 (for GA4 Data API + Search Console API)
GOOGLE_OAUTH_CLIENT_ID=CHANGE_ME_oauth_client_id
GOOGLE_OAUTH_CLIENT_SECRET=CHANGE_ME_oauth_client_secret
GOOGLE_OAUTH_REFRESH_TOKEN=CHANGE_ME_oauth_refresh_token

# Google Search Console
GSC_SITE_URL=sc-domain:yourdomain.com

# reCAPTCHA Enterprise v3 Site Key
RECAPTCHA_SITE_KEY=CHANGE_ME_recaptcha_site_key

# Google Business Profile (optional — pending API quota)
GBP_API_KEY=CHANGE_ME_gbp_api_key
GBP_ACCOUNT_ID=CHANGE_ME_gbp_account_id
GBP_LOCATION_ID=CHANGE_ME_gbp_location_id

# ─── Instagram Graph API (optional) ─────────────────────────
IG_ACCESS_TOKEN=CHANGE_ME_instagram_business_token
IG_BUSINESS_ACCOUNT_ID=CHANGE_ME_instagram_business_id

# ─── phpMyAdmin BasicAuth (htpasswd format) ─────────────────
# Generate: htpasswd -nbB admin YOUR_PASSWORD (escape $ as $$)
PMA_BASICAUTH_USERS=admin:$$apr1$$CHANGE_ME
