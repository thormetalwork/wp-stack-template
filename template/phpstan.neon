parameters:
    level: 5
    paths:
        - data/wordpress/wp-content/plugins/{{PLUGIN_SLUG}}
    excludePaths:
        - data/wordpress/wp-content/plugins/{{PLUGIN_SLUG}}/assets
    scanDirectories:
        - data/wordpress
    ignoreErrors:
        # WordPress global functions not recognized without stubs
        - '#Function [a-z_]+ not found#'
        # WordPress global variables
        - '#Variable \$wpdb might not be defined#'
        # WordPress constants
        - '#Constant [A-Z_]+ not found#'
        # WordPress classes not in scan path
        - '#Class (WP_|wpdb)[a-zA-Z_]* not found#'
        # WordPress hook callbacks with mixed parameter types
        - '#Parameter .* expects .*, .* given#'
        # Variables from WordPress includes/requires context
        - '#Variable \$[a-z_]+ might not be defined#'
        # Static methods called via WordPress hooks/migrations
        - '#Static method .+::(ensure_|register_|activate_|deactivate_).+ is unused#'
    treatPhpDocTypesAsCertain: false
    reportUnmatchedIgnoredErrors: false
